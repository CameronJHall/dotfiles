" ── Display ──────────────────────────────────────────────────
syntax on
set number
set relativenumber
set cursorline
set showcmd
set showmode
set laststatus=2
set ruler

" ── Search ───────────────────────────────────────────────────
set hlsearch
set incsearch
set ignorecase
set smartcase

" ── Indentation ──────────────────────────────────────────────
set autoindent
set smartindent
set expandtab
set tabstop=4
set shiftwidth=4
set shiftround

" ── Editing ──────────────────────────────────────────────────
set backspace=indent,eol,start
set scrolloff=8
set sidescrolloff=8
set wrap
set linebreak

" ── Files ────────────────────────────────────────────────────
set noswapfile
set nobackup
set nowritebackup
set autoread

" ── Misc ─────────────────────────────────────────────────────
set wildmenu
set wildmode=longest:full,full
set mouse=a
set ttimeoutlen=50
