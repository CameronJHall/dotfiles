# Clipboard
clipboard-read = allow
copy-on-select = clipboard
clipboard-trim-trailing-spaces = true

# Theme
theme = Everforest Dark Hard
background = #1e2326
foreground = #d3c6aa
selection-background = #4c3743
selection-foreground = #d3c6aa
selection-invert-fg-bg = true

# Cursor
cursor-color = #e69875
cursor-text = #4c3743
cursor-style = block
cursor-style-blink = true

# Palette
palette = 0=#7a8478
palette = 1=#e67e80
palette = 2=#a7c080
palette = 3=#dbbc7f
palette = 4=#7fbbb3
palette = 5=#d699b6
palette = 6=#83c092
palette = 7=#f2efdf
palette = 8=#a6b0a0
palette = 9=#f85552
palette = 10=#8da101
palette = 11=#dfa000
palette = 12=#3a94c5
palette = 13=#df69ba
palette = 14=#35a77c
palette = 15=#fffbef

# Font
font-family = IosevkaTerm Nerd Font Mono
font-size = 14
font-feature = -liga
font-thicken = true

# Mouse
mouse-hide-while-typing = true
mouse-shift-capture = true

# Shell Integration
shell-integration-features = cursor

# Scrolling
scrollback-limit = 100000

# Window
window-save-state = always
window-padding-balance = true
macos-titlebar-style = transparent
